# Marque visible par le client (connexion + barre latérale). Sinon libellé par défaut : UpStay
# NEXT_PUBLIC_APP_NAME=Nom du lieu ou du client
# NEXT_PUBLIC_APP_AUTH_INTRO=Texte personnalisé sous le titre « Connexion » (optionnel).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Optionnel (même URL) pour les API routes si tu préfères une var serveur dédiée :
# SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Alternative acceptée par le middleware (docs Supabase) :
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé secrète « service_role » (Settings → API) — obligatoire pour /api/weddings.
# Ne pas mettre la clé anon ici : les lignes resteraient vides à cause du RLS.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Table Supabase des modèles d'e-mail (page Automatisations). Défaut : automation_settings
# SUPABASE_AUTOMATION_SETTINGS_TABLE=automation_settings
#
# Création SQL une fois : voir commentaire en tête de lib/automation-settings-store.ts

# Facultatif : emails autorisés (virgules). Vide = tous les comptes Supabase Auth.
# INTERNAL_ALLOWED_EMAILS=chef@entreprise.fr,collegue@entreprise.fr

# Envoi d'emails automatiques (Resend)
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM_EMAIL=Relances Mariage <onboarding@resend.dev>
#
# Secret pour sécuriser les routes d'automatisation (Bearer ou x-automation-secret)
# AUTOMATION_SECRET=un-secret-long-et-aleatoire
#
# Vercel Cron : définir CRON_SECRET dans le dashboard Vercel ; Vercel envoie
# Authorization: Bearer <CRON_SECRET>. Tu peux utiliser la même valeur que AUTOMATION_SECRET.
# CRON_SECRET=meme-valeur-ou-separee
